{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "trailingCommas": "es5",
      "semicolons": "always"
    }
  },
  "files": {
    "ignore": [
      "node_modules",
      "dist",
      "target",
      ".worktrees",
      "apps/desktop/src-tauri/target",
      "apps/desktop/src-tauri/gen",
      "apps/desktop/src-tauri/binaries",
      "packages/core/src/builtin-graph-playbook-bundles.generated.ts",
      "**/graphify-out",
      ".graphify_python",
      ".omx",
      "bun.lockb"
    ]
  }
}
