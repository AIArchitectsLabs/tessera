{
  "schemaVersion": 1,
  "meta": {
    "id": "ops.activity-snapshot",
    "version": 1,
    "name": "Activity Snapshot",
    "description": "Refreshable dashboard of recent workspace activity.",
    "author": "Tessera"
  },
  "workflow": {
    "id": "ops.activity-snapshot",
    "version": 1,
    "name": "Activity Snapshot",
    "description": "Refreshable dashboard of recent workspace activity.",
    "category": "operations",
    "businessUseCase": "Latest workspace update",
    "requiredCapabilities": [],
    "optionalCapabilities": ["drive", "mail", "calendar"],
    "outputs": [
      {
        "kind": "dashboard",
        "label": "Activity dashboard",
        "layout": "layouts/dashboard.json"
      }
    ],
    "phaseOrder": ["Summarize"],
    "start": "draftSnapshot",
    "inputs": {
      "scope": {
        "type": "string",
        "required": true,
        "label": "Scope",
        "default": "this week",
        "order": 1,
        "group": "Dashboard",
        "ui": {
          "control": "text"
        }
      },
      "workspaceRoot": {
        "type": "string",
        "required": true,
        "label": "Workspace",
        "group": "System",
        "ui": {
          "control": "text"
        }
      }
    },
    "steps": [
      {
        "id": "draftSnapshot",
        "label": "Draft activity snapshot",
        "phase": "Summarize",
        "kind": "agent",
        "prompt": "file:prompts/draft-snapshot.md",
        "workspaceRootInput": "workspaceRoot",
        "onSuccess": "completed",
        "onFailure": "failed"
      }
    ]
  }
}
