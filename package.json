{
  "name": "tessera",
  "private": true,
  "workspaces": [
    "apps/desktop",
    "apps/desktop/ui",
    "apps/sidecar",
    "apps/cli",
    "packages/*",
    "plugins/*"
  ],
  "scripts": {
    "dev": "bun run --filter @tessera/desktop dev",
    "build": "bun run --filter '*' build",
    "build:sidecar": "bun run scripts/build-sidecar.ts",
    "check": "biome check . && bun run --filter '*' typecheck",
    "test": "bun run --filter '*' test"
  },
  "devDependencies": {
    "@biomejs/biome": "^1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/jsdom": "^28.0.1",
    "jsdom": "^29.1.1",
    "typescript": "^5"
  }
}
