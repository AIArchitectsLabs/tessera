{
  "name": "@tessera/cli",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "tessera": "./dist/cli"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build --compile --target=bun src/index.ts --outfile dist/cli",
    "typecheck": "tsc --noEmit",
    "test": "bun test --pass-with-no-tests"
  },
  "dependencies": {
    "@tessera/contracts": "workspace:*",
    "@tessera/core": "workspace:*",
    "node-html-markdown": "^2.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
