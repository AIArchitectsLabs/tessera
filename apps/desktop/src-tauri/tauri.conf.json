{
  "$schema": "https://schema.tauri.app/config/2.json",
  "productName": "Tessera",
  "version": "0.1.0",
  "identifier": "dev.tessera.app",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun --cwd ../.. run build:sidecar && bun run --filter @tessera/ui dev",
    "beforeBuildCommand": "bun --cwd ../.. run build:sidecar && bun run --filter @tessera/ui build"
  },
  "app": {
    "windows": [
      {
        "title": "Tessera",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.png"],
    "externalBin": ["binaries/tessera-sidecar", "binaries/tessera-cli"]
  },
  "plugins": {
    "shell": {
      "open": false
    }
  }
}
